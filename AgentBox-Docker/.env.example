# AgentBox 镜像地址。
# 生产环境建议固定版本号，例如 1.0.0；不要随意使用 latest，方便回滚。
AGENTBOX_IMAGE=crpi-k39e7iu8opdpbjdg.cn-hangzhou.personal.cr.aliyuncs.com/orence/agentbox:1.0.0

# 容器名称。单机部署多个实例时必须改成不同值。
AGENTBOX_CONTAINER_NAME=agentbox

# 宿主机端口映射。
# AgentBox 控制台：http://宿主机:8787
AGENTBOX_PORT=8787
# OpenClaw Gateway：http://宿主机:18789 或 ws://宿主机:18789
OPENCLAW_GATEWAY_PORT=18789
# WebDAV：http://宿主机:8080
WEBDAV_PORT=8080

# 持久化目录。
# 宿主机只挂载一个实例目录到容器 /root/.AgentBox-Data。
# OpenClaw、Hermes、CC-Connect、Codex、Claude、缓存和 WebDAV 文件都在这个目录里。
AGENTBOX_DATA_DIR=./data

# AgentBox 登录 Token。
# 留空时 AgentBox 会自动生成认证配置；需要固定登录地址时可以填一个长随机字符串。
AUTH_DEFAULT_TOKEN=

# AgentBox 公网访问地址。
# 例如：https://openclaw-1001-agentbox.example.com
# 这个地址会被加入 OpenClaw Control UI allowedOrigins。
AGENTBOX_PUBLIC_URL=

# 额外允许访问 OpenClaw Control UI 的 Origin，多个值可按 AgentBox 后端支持的格式填写。
# 通常只填 AGENTBOX_PUBLIC_URL 就够了。
AGENTBOX_CONTROL_UI_ORIGINS=

# OpenClaw Gateway 公网访问地址。
# 例如：https://openclaw-1001.example.com
# 浏览器前端需要通过这个地址连接远程 Gateway。
OPENCLAW_PUBLIC_GATEWAY_URL=

# OpenClaw Gateway Token。留空时由安装流程/配置生成或使用 AgentBox 的访问密钥。
OPENCLAW_GATEWAY_TOKEN=

# 如果需要在浏览器里允许私有地址 ws:// 直连，可按 AgentBox/OpenClaw 前端逻辑启用。
# 公网 HTTPS 部署通常不需要填写。
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=

# 内置 WebDAV。
# WEBDAV_ENABLED=1 表示启用；设置 WEBDAV_USER 和 WEBDAV_PASS 后会开启 Basic Auth。
WEBDAV_ENABLED=1
WEBDAV_USER=
WEBDAV_PASS=

# AgentBox 二进制清单。容器启动时会从这里拉取当前 Linux 版本。
AGENTBOX_MANIFEST_URL=https://agent.orence.net/releases/latest.json
# 是否强制校验 sha256。0 表示校验失败只警告，1 表示校验失败直接退出。
AGENTBOX_STRICT_SHA256=0

# 模型目录和初始化配置。
MODEL_CATALOG_URL=https://agent.orence.net/releases/models.json
MODEL_INITIALIZATION_URL=https://agent.orence.net/releases/model-initialization.json

# 时区和日志级别。
TZ=Asia/Shanghai
LOG_LEVEL=info
