# 生产环境使用方式：
# 将本文件复制为 .env，并放在后端二进制文件同级目录。
# 如果系统环境变量已经设置了同名变量，系统环境变量优先，本文件不会覆盖。

APP_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=8787

# 留空时使用默认路径：~/.agent-box/data.db
DATABASE_URL=

# 留空时使用默认路径：~/.agent-box/auth.json
AUTH_CONFIG_PATH=

# 可选：仅在 auth.json 不存在、首次生成时写入默认 Token；文件已存在后实际鉴权仍以 auth.json 为准
AUTH_DEFAULT_TOKEN=

# 日志级别：debug、info、warn、error
LOG_LEVEL=info

# 可选：模型目录 URL，留空时使用默认 https://agent.orence.net/releases/models.json
MODEL_CATALOG_URL=

# 可选：模型初始化 URL，留空时使用默认 https://agent.orence.net/releases/model-initialization.json
MODEL_INITIALIZATION_URL=

# 可选：Hermes 配置目录，留空时使用默认 ~/.hermes
HERMES_HOME=

# 可选：是否展示项目级 Hermes 插件
HERMES_ENABLE_PROJECT_PLUGINS=false

# 可选：CC-Connect 配置文件路径
CC_CONNECT_CONFIG=

# 可选：OpenClaw 配置目录，留空时使用默认 ~/.openclaw
OPENCLAW_HOME=

# 可选：OpenClaw 公网 Gateway HTTP 地址。
# 前端直连 Gateway 时会自动由 http(s) 推导为 ws(s)，例如 https://openclaw.example.com -> wss://openclaw.example.com
OPENCLAW_PUBLIC_GATEWAY_URL=

# 可选：OpenClaw Agent 工作区模板目录
OPENCLAW_WORKSPACE_TEMPLATE_DIR=

# 可选：Codex / Claude 配置目录，用于技能和配置发现
CODEX_HOME=
CLAUDE_CONFIG_DIR=

# 可选：后端执行安装命令时继承的代理变量。
# 通常不需要手动填写，应用内“代理设置”会自动为后端命令注入代理。
# HTTP_PROXY=http://user:pass@proxy.example.com:7890
# HTTPS_PROXY=http://user:pass@proxy.example.com:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=127.0.0.1,localhost,::1
