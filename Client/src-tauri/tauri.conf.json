{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentBox",
  "version": "1.0.0",
  "identifier": "net.orence.agentbox",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "../Build/scripts/build.sh",
    "frontendDist": "http://127.0.0.1:8787",
    "devUrl": "http://localhost:5122"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "externalBin": [
      "binaries/agentbox-sidecar"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/installer-hooks.nsh",
        "uninstallerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCNDMzQzkzNEUxQUI2NTAKUldSUXRocE9renhEZXdxN21zTXJQa3VSRmlJMEl5dy9RSlpHNVU4NU13T0tPVVpvb2VlMEFndDgK",
      "endpoints": [
        "https://agent.orence.net/releases/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
